# ============ SUPABASE CONFIGURATION ============
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ============ RAZORPAY CONFIGURATION ============
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
# Secret you set when creating the webhook in Razorpay Dashboard → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ============ STRIPE CONFIGURATION ============
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# ============ EMAIL (verification codes & trial reminders) ============
# For Gmail: create an App Password at https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=your.email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password

# ============ SERVER CONFIGURATION ============
PORT=3001
NODE_ENV=production

# ============ ADMIN ACCESS ============
ADMIN_API_KEY=your-secret-admin-key-12345

# ============ DATABASE ============
DATABASE_URL=postgresql://user:password@localhost:5432/leftoff_db

# ============ DODO PAYMENTS (international payments) ============
# Signing secret from Dodo Dashboard → Settings → Webhooks
DODO_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ============ BREVO (HTTPS email — required on Render free tier) ============
# Render free tier blocks SMTP ports; Brevo sends over HTTPS instead.
# Sign up free at brevo.com, verify your sender email, create an API key.
BREVO_API_KEY=xkeysib-xxxxxxxxxxxx
